# ============================================
# AI Solver Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in values

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-string
LOG_LEVEL=DEBUG

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_ADMIN_IDS=[123456789, 987654321]
# TELEGRAM_PAYMENT_PROVIDER_TOKEN=your_payment_token (removed - premium removed)

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aisolver
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.3

# OpenRouter
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.3

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Default AI Provider
DEFAULT_AI_PROVIDER=openai
AI_FALLBACK_ENABLED=true
AI_STREAMING_ENABLED=true

# OCR
OCR_ENABLED=true
TESSERACT_CMD=/usr/bin/tesseract
MATHPIX_API_KEY=
MATHPIX_APP_ID=
MAX_IMAGE_SIZE_MB=10

# User Limits
DAILY_LIMIT=20
TOKENS_PER_MONTH=100000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Referrals
REFERRAL_ENABLED=true
REFERRAL_BONUS_DAYS=3
REFERRAL_BONUS_TOKENS=10000

# Workers
WORKER_CONCURRENCY=5
WORKER_TIMEOUT_SECONDS=300

# Monitoring
SENTRY_DSN=
