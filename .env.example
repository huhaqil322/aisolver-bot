# ============================================
# AI Solver Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in values

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-string
LOG_LEVEL=DEBUG

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_ADMIN_IDS=[123456789, 987654321]

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aisolver

# Redis
REDIS_URL=redis://localhost:6379/0

# ============================================
# Google Gemini — БЕСПЛАТНЫЙ AI (по умолчанию)
# ============================================
# 1. Получи бесплатный API ключ: https://aistudio.google.com/apikey
# 2. Это бесплатно (60 запросов/мин, до 1500 в день)
# 3. Вставь ключ ниже
GEMINI_API_KEY=AIza-your-free-gemini-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.3

# OpenRouter (платный, но модели мощнее)
# Зарегистрируйся на https://openrouter.ai, создай ключ, пополни баланс
# OPENROUTER_API_KEY=sk-or-v1-your-key
# OPENROUTER_MODEL=openai/gpt-4o

# OpenAI / Anthropic (тоже платные)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Default AI Provider (gemini, openrouter, openai, anthropic)
DEFAULT_AI_PROVIDER=gemini
AI_FALLBACK_ENABLED=true
AI_STREAMING_ENABLED=true

# OCR
OCR_ENABLED=true
TESSERACT_CMD=/usr/bin/tesseract
MATHPIX_API_KEY=
MATHPIX_APP_ID=
MAX_IMAGE_SIZE_MB=10

# User Limits
DAILY_LIMIT=20
TOKENS_PER_MONTH=100000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Referrals
REFERRAL_ENABLED=true
REFERRAL_BONUS_DAYS=3
REFERRAL_BONUS_TOKENS=10000

# Workers
WORKER_CONCURRENCY=5
WORKER_TIMEOUT_SECONDS=300

# Monitoring
SENTRY_DSN=
