# ============================================
# AI Solver Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in values

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-string
LOG_LEVEL=DEBUG

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_ADMIN_IDS=[123456789, 987654321]

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aisolver

# Redis
REDIS_URL=redis://localhost:6379/0

# ============================================
# OpenRouter — БЕСПЛАТНЫЕ МОДЕЛИ (по умолчанию)
# ============================================
# 1. Зарегистрируйся на https://openrouter.ai
# 2. Создай API ключ: https://openrouter.ai/keys
# 3. Вставь ключ ниже (пополнять баланс НЕ нужно для free моделей)
# 4. Список бесплатных моделей: https://openrouter.ai/models?order=newest&free=1
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.3

# Другие провайдеры (опционально)
# GEMINI_API_KEY=AIza-your-key
# OPENAI_API_KEY=

# Default AI Provider (openrouter, gemini, openai, anthropic)
DEFAULT_AI_PROVIDER=openrouter
AI_FALLBACK_ENABLED=true
AI_STREAMING_ENABLED=true

# OCR
OCR_ENABLED=true
TESSERACT_CMD=/usr/bin/tesseract
MATHPIX_API_KEY=
MATHPIX_APP_ID=
MAX_IMAGE_SIZE_MB=10

# User Limits
DAILY_LIMIT=20
TOKENS_PER_MONTH=100000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Referrals
REFERRAL_ENABLED=true
REFERRAL_BONUS_DAYS=3
REFERRAL_BONUS_TOKENS=10000

# Workers
WORKER_CONCURRENCY=5
WORKER_TIMEOUT_SECONDS=300

# Monitoring
SENTRY_DSN=
